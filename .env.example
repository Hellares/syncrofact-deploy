# =============================================================================
# Syncrofact - Variables de entorno
# Copiar a .env y completar los valores
# =============================================================================

# --- MySQL Root ---
DB_ROOT_PASSWORD=CAMBIAR_password_seguro

# --- BETA ---
APP_KEY_BETA=base64:GENERAR_CON_php_artisan_key_generate

# --- PRODUCCION ---
APP_KEY_PROD=base64:GENERAR_CON_php_artisan_key_generate

# --- Compartido ---
FACTILIZA_TOKEN=tu_token_factiliza

# --- Email (Amazon SES) ---
MAIL_MAILER=smtp
MAIL_HOST=email-smtp.us-east-1.amazonaws.com
MAIL_PORT=587
MAIL_USERNAME=tu_smtp_username
MAIL_PASSWORD=tu_smtp_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@syncrofact.net.pe
MAIL_FROM_NAME=Syncrofact
